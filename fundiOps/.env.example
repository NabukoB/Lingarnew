# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# OpenAI
OPENAI_API_KEY=sk-...

# Mailgun (for follow-up reminder emails)
MAILGUN_API_KEY=key-...
MAILGUN_DOMAIN=your-domain.com
MAILGUN_FROM=fundiops@your-domain.com

# WhatsApp Business Cloud API (Meta)
WHATSAPP_ACCESS_TOKEN=your-permanent-system-user-access-token
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id
WHATSAPP_WEBHOOK_VERIFY_TOKEN=a-random-secret-you-choose-for-verification
WHATSAPP_BUSINESS_ACCOUNT_ID=your-waba-id
WHATSAPP_APP_SECRET=your-meta-app-secret

# App
NEXT_PUBLIC_APP_URL=https://fundiops.vercel.app
CRON_SECRET=replace-with-random-64-char-string

# CRM owner (single-tenant: Supabase UUID of the business owner)
WHATSAPP_OWNER_USER_ID=your-supabase-user-uuid
