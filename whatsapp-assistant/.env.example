# Claude (Anthropic) API key — https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# WhatsApp Business Cloud API — https://developers.facebook.com/docs/whatsapp/cloud-api
# Phone number ID for the business number sending replies
WHATSAPP_PHONE_NUMBER_ID=123456789012345
# Permanent (or system-user) access token with whatsapp_business_messaging permission
WHATSAPP_ACCESS_TOKEN=EAAG...
# Verify token you choose; must match what you enter in the Meta webhook UI
WHATSAPP_VERIFY_TOKEN=some-random-string

# Optional: describe the business so Claude can answer in-brand
BUSINESS_NAME=Acme Coffee
BUSINESS_CONTEXT=We are a small coffee shop in Nairobi. Hours: Mon-Sat 7am-7pm. We sell espresso drinks, pastries, and whole beans. Delivery via Glovo. For orders over KES 2000 we deliver free within Kilimani.

# Optional: port for the webhook server (default 3000)
PORT=3000
