# Claude (Anthropic) API key — https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# Twilio WhatsApp — https://www.twilio.com/docs/whatsapp
# Get these from the Twilio Console: https://console.twilio.com/
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-auth-token
# The WhatsApp-enabled sender, with the "whatsapp:" prefix.
# Use "whatsapp:+14155238886" for the Twilio sandbox during testing,
# or your approved WhatsApp Business Sender for production.
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# Optional: public URL where Twilio reaches this service (used to verify
# request signatures). Set this in production; leave blank to skip signature
# checks during local dev with ngrok.
PUBLIC_URL=

# Optional: describe the business so Claude can answer in-brand
BUSINESS_NAME=Acme Coffee
BUSINESS_CONTEXT=We are a small coffee shop in Nairobi. Hours: Mon-Sat 7am-7pm. We sell espresso drinks, pastries, and whole beans. Delivery via Glovo. For orders over KES 2000 we deliver free within Kilimani.

# Optional: port for the webhook server (default 3000)
PORT=3000
