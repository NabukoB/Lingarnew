# Alpaca — trading & market data
ALPACA_API_KEY=your-alpaca-key-id
ALPACA_SECRET_KEY=your-alpaca-secret-key
# Paper endpoint by default. Live is https://api.alpaca.markets — do not switch
# without also setting LIVE_TRADING_CONFIRMED=true below.
ALPACA_BASE_URL=https://paper-api.alpaca.markets
ALPACA_DATA_URL=https://data.alpaca.markets

# Must be the literal string "true" to allow trading against a non-paper
# ALPACA_BASE_URL. Leave unset while validating the strategy.
LIVE_TRADING_CONFIRMED=

# Risk rails (see tradingAgent/scripts/alpaca.mjs)
MAX_POSITION_PCT=10
MAX_OPEN_POSITIONS=5
MAX_DAILY_LOSS_PCT=3

# Mailgun — recap email (same service as the root app's src/lib/mailgun/send.ts)
MAILGUN_API_KEY=your-mailgun-api-key
MAILGUN_DOMAIN=your-mailgun-domain
MAILGUN_FROM=trading-agent@your-mailgun-domain
RECAP_EMAIL_TO=you@example.com
RECAP_EMAIL_TO_NAME=
