# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# OpenAI
OPENAI_API_KEY=sk-...

# Mailgun inbound routing
MAILGUN_WEBHOOK_SIGNING_KEY=your-webhook-signing-key
# (The signing key is under Mailgun > Webhooks, not the API key)

# App
NEXT_PUBLIC_APP_URL=https://lingar.app

# Secret for the daily digest CRON route
CRON_SECRET=replace-with-random-64-char-string
